{
  "manifest_version": 3,
  "name": "KinoFinder — плеер для IMDb и Кинопоиска",
  "version": "1.0.3",
  "description": "На странице фильма/сериала на IMDb или Кинопоиске добавляет кнопку «Смотреть онлайн» и открывает окно с плеером (kinoboxtv.tatnet.app / kinoplayertop.tatnet.app) — показывается тот источник, который откроется первым.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.imdb.com/*",
    "*://*.kinopoisk.ru/*",
    "*://kinoboxtv.tatnet.app/*",
    "*://kinoplayertop.tatnet.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "KinoFinder",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.imdb.com/title/*"],
      "js": ["content_imdb.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.kinopoisk.ru/film/*",
        "*://*.kinopoisk.ru/series/*"
      ],
      "js": ["content_kp.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["player.html", "player.css", "player.js", "icons/*"],
      "matches": ["*://*.imdb.com/*", "*://*.kinopoisk.ru/*"]
    }
  ]
}
